# ============================================================
# ECHOMIND COMMERCE - env schema (committed, placeholders only)
# ============================================================
# Copy to .env and fill with real values. Never commit .env.
# ============================================================

# ---------- Gemini (Google AI Studio) ----------
# Get at: https://aistudio.google.com/apikey
GEMINI_API_KEY=
GEMINI_FLASH_MODEL=gemini-2.5-flash
GEMINI_PRO_MODEL=gemini-2.5-pro
GEMINI_EMBEDDING_MODEL=text-embedding-004

# ---------- OpenRouter (agent swarm) ----------
# Get at: https://openrouter.ai/keys
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_AGENT_LLAMA=meta-llama/llama-3.3-70b-instruct:free
OPENROUTER_AGENT_QWEN=qwen/qwen-2.5-72b-instruct:free
OPENROUTER_AGENT_DEEPSEEK=deepseek/deepseek-chat:free
OPENROUTER_AGENT_GEMINI=google/gemini-2.0-flash-exp:free

# ---------- Neo4j AuraDB ----------
# Get at: https://console.neo4j.io (Free tier: 50K nodes / 175K edges)
NEO4J_URI=neo4j+s://YOUR_INSTANCE.databases.neo4j.io
NEO4J_USERNAME=
NEO4J_PASSWORD=
NEO4J_DATABASE=

# ---------- Firebase (client-side, public config) ----------
# Get at: Firebase Console → Project Settings → Your apps → Web SDK config
FIREBASE_API_KEY=
FIREBASE_AUTH_DOMAIN=
FIREBASE_PROJECT_ID=
FIREBASE_STORAGE_BUCKET=
FIREBASE_MESSAGING_SENDER_ID=
FIREBASE_APP_ID=
FIREBASE_MEASUREMENT_ID=

# ---------- Firebase Admin SDK (server-side) ----------
# Firebase Console → Project Settings → Service Accounts → Generate private key
GOOGLE_APPLICATION_CREDENTIALS=./firebase-admin-credentials.json

# ---------- Shopify ----------
# Create custom app: admin.shopify.com/store/<HANDLE>/settings/apps/development
SHOPIFY_STORE_DOMAIN=YOUR-STORE.myshopify.com
SHOPIFY_API_KEY=
SHOPIFY_API_SECRET=
SHOPIFY_ADMIN_ACCESS_TOKEN=
SHOPIFY_STOREFRONT_ACCESS_TOKEN=
SHOPIFY_API_VERSION=2025-01

# ---------- Backend ----------
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
LOG_LEVEL=INFO
ENV=local

# ---------- Frontend ----------
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
NEXT_PUBLIC_WS_BASE_URL=ws://localhost:8000
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=
